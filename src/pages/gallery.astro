---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
import { readdir } from 'fs/promises';
import path from 'path';

// Auto-scan public/images/ — just drop files in, no config needed.
// Naming convention for captions: use hyphens or underscores as word separators.
//   hawaii-sunset.jpg        → caption: "Hawaii sunset"
//   ron-vanessa-dinner.jpg   → caption: "Ron vanessa dinner"
//   IMG_2663.jpg             → no caption (generic camera filenames ignored)

const imageDir = path.join(process.cwd(), 'public/images');
const validExtensions = ['.jpg', '.jpeg', '.png', '.gif', '.webp', '.JPG', '.JPEG', '.PNG', '.WEBP'];

// Filenames that look like camera defaults — no caption shown
const genericPattern = /^(IMG|DSC|DCIM|photo|image|screenshot)[-_]?\d+$/i;

let photos: { src: string; alt: string; caption: string }[] = [];

try {
	const files = await readdir(imageDir);
	photos = files
		.filter(f => validExtensions.includes(path.extname(f)))
		.sort()
		.map(f => {
			const base = path.basename(f, path.extname(f));
			const words = base.replace(/[-_]+/g, ' ').trim();
			const isGeneric = genericPattern.test(base);
			const caption = isGeneric ? '' : words.charAt(0).toUpperCase() + words.slice(1);
			return {
				src: `/images/${f}`,
				alt: words,
				caption,
			};
		});
} catch (e) {
	// public/images/ doesn't exist yet — gallery will show empty state
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Gallery | ${SITE_TITLE}`} description="Photo gallery" />
		<style>
			.gallery-header {
				margin-bottom: 2em;
			}
			.gallery-header h1 {
				font-size: 2.441em;
				margin-bottom: 0.25em;
			}
			.gallery-header p {
				color: rgb(var(--gray));
				margin: 0;
			}
			.gallery-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1.5em;
			}
			.photo-card {
				display: flex;
				flex-direction: column;
				border-radius: 8px;
				overflow: hidden;
				box-shadow: var(--box-shadow);
				transition: transform 0.2s ease, box-shadow 0.2s ease;
			}
			.photo-card:hover {
				transform: translateY(-4px);
				box-shadow: 0 8px 24px rgba(var(--gray), 40%);
			}
			.photo-card img {
				width: 100%;
				height: 220px;
				object-fit: cover;
				border-radius: 0;
				display: block;
				cursor: pointer;
			}
			.photo-card .caption {
				padding: 0.75em 1em;
				font-size: 0.9em;
				color: rgb(var(--gray-dark));
				background: white;
			}
			.empty-state {
				grid-column: 1 / -1;
				text-align: center;
				padding: 4em 2em;
				color: rgb(var(--gray));
				border: 2px dashed rgb(var(--gray-light));
				border-radius: 8px;
			}
			.empty-state p {
				margin: 0;
				font-size: 0.95em;
			}
			/* Lightbox overlay */
			.lightbox {
				display: none;
				position: fixed;
				inset: 0;
				background: rgba(0, 0, 0, 0.85);
				z-index: 1000;
				align-items: center;
				justify-content: center;
				cursor: pointer;
			}
			.lightbox.open {
				display: flex;
			}
			.lightbox img {
				max-width: 90vw;
				max-height: 90vh;
				object-fit: contain;
				border-radius: 4px;
				box-shadow: 0 8px 40px rgba(0,0,0,0.6);
				cursor: default;
			}
			.lightbox-close {
				position: absolute;
				top: 1.5em;
				right: 1.5em;
				color: white;
				font-size: 2em;
				cursor: pointer;
				line-height: 1;
				opacity: 0.8;
			}
			.lightbox-close:hover {
				opacity: 1;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="gallery-header">
				<h1>Gallery</h1>
				<p>Photos worth keeping.</p>
			</div>

			<div class="gallery-grid">
				{photos.length === 0 ? (
					<div class="empty-state">
						<p>No photos yet — drop image files into <code>public/images/</code> and they'll appear here automatically.</p>
					</div>
				) : (
					photos.map((photo, i) => (
						<div class="photo-card" data-index={i}>
							<img
								src={photo.src}
								alt={photo.alt}
								loading="lazy"
								data-src={photo.src}
								data-alt={photo.alt}
							/>
							{photo.caption && <div class="caption">{photo.caption}</div>}
						</div>
					))
				)}
			</div>
		</main>

		<!-- Lightbox -->
		<div class="lightbox" id="lightbox">
			<span class="lightbox-close" id="lightbox-close">&times;</span>
			<img id="lightbox-img" src="" alt="" />
		</div>

		<Footer />

		<script>
			function openLightbox(src: string, alt: string) {
				const lb = document.getElementById('lightbox');
				const img = document.getElementById('lightbox-img') as HTMLImageElement;
				if (!lb || !img) return;
				img.src = src;
				img.alt = alt;
				lb.classList.add('open');
				document.body.style.overflow = 'hidden';
			}

			function closeLightbox() {
				const lb = document.getElementById('lightbox');
				if (!lb) return;
				lb.classList.remove('open');
				document.body.style.overflow = '';
			}

			// Wire up photo cards via event listeners
			document.querySelectorAll('.photo-card img').forEach((img) => {
				img.addEventListener('click', () => {
					const src = (img as HTMLElement).dataset.src || (img as HTMLImageElement).src;
					const alt = (img as HTMLImageElement).alt;
					openLightbox(src, alt);
				});
			});

			// Close on overlay click
			document.getElementById('lightbox')?.addEventListener('click', closeLightbox);

			// Stop click on image from closing lightbox
			document.getElementById('lightbox-img')?.addEventListener('click', (e) => {
				e.stopPropagation();
			});

			// Close button
			document.getElementById('lightbox-close')?.addEventListener('click', (e) => {
				e.stopPropagation();
				closeLightbox();
			});

			// Close on Escape key
			document.addEventListener('keydown', (e) => {
				if (e.key === 'Escape') closeLightbox();
			});
		</script>
	</body>
</html>
