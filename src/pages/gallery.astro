---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
import { getAlbums } from '../lib/cloudinary';

const { albums, error } = await getAlbums();
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Gallery | ${SITE_TITLE}`} description="Family photo albums" />
		<style>
			body {
				background: #f4f6fb;
				background-size: unset;
			}
			body > main {
				padding-top: 0;
			}

			.page-header {
				background: #1a2744;
				color: white;
				text-align: center;
				padding: 3em 1em 2.5em;
				width: 100vw;
				position: relative;
				left: 50%;
				transform: translateX(-50%);
				margin-bottom: 2.5em;
			}
			.page-header h1 {
				font-size: 2.441em;
				margin-bottom: 0.2em;
				color: white;
			}
			.page-header p {
				color: #a8b8d8;
				margin: 0;
				font-style: italic;
			}

			.albums-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1.5em;
				margin-bottom: 3em;
			}

			.album-card {
				display: flex;
				flex-direction: column;
				border-radius: 8px;
				overflow: hidden;
				box-shadow: var(--box-shadow);
				transition: transform 0.2s ease, box-shadow 0.2s ease;
				background: white;
				text-decoration: none;
				color: inherit;
			}
			.album-card:hover {
				transform: translateY(-4px);
				box-shadow: 0 8px 24px rgba(var(--gray), 40%);
			}
			.album-cover {
				width: 100%;
				height: 200px;
				object-fit: cover;
				display: block;
			}
			.album-cover-placeholder {
				width: 100%;
				height: 200px;
				background: #1a2744;
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 3em;
			}
			.album-info {
				padding: 1em 1.1em 1.1em;
			}
			.album-year {
				font-size: 0.75em;
				font-weight: 700;
				color: var(--accent);
				text-transform: uppercase;
				letter-spacing: 0.08em;
				margin-bottom: 0.2em;
			}
			.album-name {
				font-size: 1.05em;
				font-weight: 600;
				color: rgb(var(--black));
				line-height: 1.3;
			}
			.album-count {
				font-size: 0.8em;
				color: rgb(var(--gray));
				margin-top: 0.3em;
			}

			.empty-state {
				grid-column: 1 / -1;
				text-align: center;
				padding: 4em 2em;
				color: rgb(var(--gray));
				border: 2px dashed rgb(var(--gray-light));
				border-radius: 8px;
			}
			.empty-state p { margin: 0; font-size: 0.95em; }
			.empty-state code {
				font-size: 0.9em;
				background: rgb(var(--gray-light));
				padding: 0.1em 0.4em;
				border-radius: 3px;
			}

			@media (max-width: 720px) {
				.page-header h1 { font-size: 1.953em; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>

			<div class="page-header">
				<h1>Gallery</h1>
				<p>Photos worth keeping.</p>
			</div>

			<div class="albums-grid">
				{error ? (
					<div class="empty-state">
						<p>Could not load albums: <code>{error}</code></p>
					</div>
				) : albums.length === 0 ? (
					<div class="empty-state">
						<p>
							No albums yet — create subfolders inside <code>jacobs-family</code> in
							Cloudinary named like <code>2026-Bahamas</code> and upload photos into them.
						</p>
					</div>
				) : (
					albums.map((album) => (
						<a class="album-card" href={`/gallery/${album.folder}`}>
							{album.cover ? (
								<img
									class="album-cover"
									src={album.cover}
									alt={`${album.name} cover photo`}
									loading="lazy"
									width={600}
									height={440}
								/>
							) : (
								<div class="album-cover-placeholder">📷</div>
							)}
							<div class="album-info">
								<div class="album-year">{album.year}</div>
								<div class="album-name">{album.name}</div>
								<div class="album-count">{album.count} {album.count === 1 ? 'photo' : 'photos'}</div>
							</div>
						</a>
					))
				)}
			</div>

		</main>
		<Footer />
	</body>
</html>
