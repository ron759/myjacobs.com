---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

// Pull photos from the Cloudinary content collection (defined in src/content/config.ts).
// Each entry has: id, data.public_id, data.secure_url, data.width, data.height, data.context
//
// Optional: add captions via Cloudinary's "caption" context field on any asset.
// In Cloudinary Media Library: open an asset → "Manage" tab → Context → add key "caption".

let photos: { publicId: string; src: string; width: number; height: number; caption: string }[] = [];

try {
	const assets = await getCollection('gallery');
	photos = assets.map((asset) => {
		const caption = asset.data.context?.caption ?? asset.data.context?.alt ?? '';
		return {
			publicId: asset.data.public_id,
			src: asset.data.secure_url,
			width: asset.data.width,
			height: asset.data.height,
			caption,
		};
	});
} catch (e) {
	// Collection not yet defined or Cloudinary not configured — shows empty state
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Gallery | ${SITE_TITLE}`} description="Photo gallery" />
		<style>
			body {
				background: #f4f6fb;
				background-size: unset;
			}

			body > main {
				padding-top: 0;
			}

			.page-header {
				background: #1a2744;
				color: white;
				text-align: center;
				padding: 3em 1em 2.5em;
				width: 100vw;
				position: relative;
				left: 50%;
				transform: translateX(-50%);
				margin-bottom: 2.5em;
			}
			.page-header h1 {
				font-size: 2.441em;
				margin-bottom: 0.2em;
				color: white;
			}
			.page-header p {
				color: #a8b8d8;
				margin: 0;
				font-style: italic;
			}

			.gallery-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1.5em;
				margin-bottom: 3em;
			}

			.photo-card {
				display: flex;
				flex-direction: column;
				border-radius: 8px;
				overflow: hidden;
				box-shadow: var(--box-shadow);
				transition: transform 0.2s ease, box-shadow 0.2s ease;
				background: white;
			}
			.photo-card:hover {
				transform: translateY(-4px);
				box-shadow: 0 8px 24px rgba(var(--gray), 40%);
			}
			.photo-card img {
				width: 100%;
				height: 220px;
				object-fit: cover;
				display: block;
				cursor: pointer;
			}
			.photo-card .caption {
				padding: 0.75em 1em;
				font-size: 0.9em;
				color: rgb(var(--gray-dark));
			}

			.empty-state {
				grid-column: 1 / -1;
				text-align: center;
				padding: 4em 2em;
				color: rgb(var(--gray));
				border: 2px dashed rgb(var(--gray-light));
				border-radius: 8px;
			}
			.empty-state p {
				margin: 0;
				font-size: 0.95em;
			}
			.empty-state code {
				font-size: 0.9em;
				background: rgb(var(--gray-light));
				padding: 0.1em 0.4em;
				border-radius: 3px;
			}

			/* Lightbox */
			.lightbox {
				display: none;
				position: fixed;
				inset: 0;
				background: rgba(0, 0, 0, 0.88);
				z-index: 1000;
				align-items: center;
				justify-content: center;
				cursor: pointer;
			}
			.lightbox.open {
				display: flex;
			}
			.lightbox img {
				max-width: 90vw;
				max-height: 90vh;
				object-fit: contain;
				border-radius: 4px;
				box-shadow: 0 8px 40px rgba(0, 0, 0, 0.6);
				cursor: default;
			}
			.lightbox-close {
				position: absolute;
				top: 1.5em;
				right: 1.5em;
				color: white;
				font-size: 2em;
				cursor: pointer;
				line-height: 1;
				opacity: 0.8;
				background: none;
				border: none;
				padding: 0;
			}
			.lightbox-close:hover {
				opacity: 1;
			}
			.lightbox-caption {
				position: absolute;
				bottom: 1.5em;
				left: 50%;
				transform: translateX(-50%);
				color: rgba(255, 255, 255, 0.85);
				font-size: 0.9em;
				text-align: center;
				max-width: 80vw;
				pointer-events: none;
			}

			@media (max-width: 720px) {
				.page-header h1 {
					font-size: 1.953em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>

			<div class="page-header">
				<h1>Gallery</h1>
				<p>Photos worth keeping.</p>
			</div>

			<div class="gallery-grid">
				{photos.length === 0 ? (
					<div class="empty-state">
						<p>
							No photos yet — make sure <code>astro-cloudinary</code> is installed,
							your <code>CLOUDINARY_CLOUD_NAME</code> env var is set, and a
							<code>gallery</code> collection is defined in <code>src/content/config.ts</code>.
						</p>
					</div>
				) : (
					photos.map((photo, i) => {
						// Build a Cloudinary URL: auto format + quality, crop to fill at 600×440 (2× card size)
						const optimizedSrc = photo.src.replace(
							'/upload/',
							'/upload/f_auto,q_auto,w_600,h_440,c_fill/'
						);
						// Full-res URL for lightbox (cap at 1600px wide, still auto format/quality)
						const fullSrc = photo.src.replace(
							'/upload/',
							'/upload/f_auto,q_auto,w_1600/'
						);
						return (
							<div
								class="photo-card"
								data-index={i}
								data-full={fullSrc}
								data-caption={photo.caption}
							>
								<img
									src={optimizedSrc}
									alt={photo.caption || `Photo ${i + 1}`}
									loading="lazy"
									width={600}
									height={440}
								/>
								{photo.caption && <div class="caption">{photo.caption}</div>}
							</div>
						);
					})
				)}
			</div>

		</main>

		<!-- Lightbox -->
		<div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Photo viewer">
			<button class="lightbox-close" id="lightbox-close" aria-label="Close">&times;</button>
			<img id="lightbox-img" src="" alt="" />
			<div class="lightbox-caption" id="lightbox-caption"></div>
		</div>

		<Footer />

		<script>
			const lightbox     = document.getElementById('lightbox')!;
			const lbImg        = document.getElementById('lightbox-img') as HTMLImageElement;
			const lbCaption    = document.getElementById('lightbox-caption')!;
			const lbClose      = document.getElementById('lightbox-close')!;

			function openLightbox(src: string, alt: string, caption: string) {
				lbImg.src        = src;
				lbImg.alt        = alt;
				lbCaption.textContent = caption;
				lightbox.classList.add('open');
				document.body.style.overflow = 'hidden';
				lbClose.focus();
			}

			function closeLightbox() {
				lightbox.classList.remove('open');
				document.body.style.overflow = '';
			}

			// Wire up cards
			document.querySelectorAll<HTMLElement>('.photo-card').forEach((card) => {
				card.addEventListener('click', () => {
					const full    = card.dataset.full    ?? '';
					const caption = card.dataset.caption ?? '';
					const img     = card.querySelector('img');
					const alt     = img?.alt ?? '';
					openLightbox(full, alt, caption);
				});
			});

			// Close on backdrop click
			lightbox.addEventListener('click', closeLightbox);

			// Stop clicks on the image or close button from bubbling to backdrop
			lbImg.addEventListener('click',   (e) => e.stopPropagation());
			lbClose.addEventListener('click',  (e) => { e.stopPropagation(); closeLightbox(); });

			// Keyboard
			document.addEventListener('keydown', (e) => {
				if (e.key === 'Escape') closeLightbox();
			});
		</script>
	</body>
</html>
