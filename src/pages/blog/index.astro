---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog | ${SITE_TITLE}`} description="All posts from The Jacobs Family." />
		<style is:global>
			body {
				background: #f4f6fb;
				background-size: unset;
			}

			body > main {
				padding-top: 0;
			}

			.page-header {
				background: #1a2744;
				color: white;
				text-align: center;
				padding: 3em 1em 2.5em;
				width: 100vw;
				position: relative;
				left: 50%;
				transform: translateX(-50%);
				margin-bottom: 2.5em;
			}
			.page-header h1 {
				font-size: 2.441em;
				margin-bottom: 0.2em;
				color: white;
			}
			.page-header p {
				color: #a8b8d8;
				margin: 0;
				font-style: italic;
			}

			.post-list {
				list-style: none;
				padding: 0;
				margin: 0 0 3em;
			}
			.post-list li {
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.post-list li:first-child {
				border-top: 1px solid rgb(var(--gray-light));
			}
			.post-list a {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				gap: 1.5em;
				padding: 1.25em 0;
				text-decoration: none;
				color: rgb(var(--black));
				transition: color 0.15s ease;
			}
			.post-list a:hover .post-title {
				color: var(--accent);
			}
			.post-title {
				font-size: 1.1em;
				font-weight: 600;
				line-height: 1.4;
				transition: color 0.15s ease;
			}
			.post-meta {
				display: flex;
				flex-direction: column;
				align-items: flex-end;
				gap: 0.25em;
				flex-shrink: 0;
			}
			.post-date {
				font-size: 0.85em;
				color: rgb(var(--gray));
				white-space: nowrap;
			}
			.empty-state {
				text-align: center;
				padding: 4em 2em;
				color: rgb(var(--gray));
				border: 2px dashed rgb(var(--gray-light));
				border-radius: 8px;
				margin-bottom: 3em;
			}

			@media (max-width: 720px) {
				.page-header h1 {
					font-size: 1.953em;
				}
				.post-list a {
					flex-direction: column;
					gap: 0.25em;
				}
				.post-meta {
					align-items: flex-start;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>

			<div class="page-header">
				<h1>The Blog</h1>
				<p>Family updates, travel notes, and whatever's on our minds.</p>
			</div>

			{posts.length === 0 ? (
				<div class="empty-state">
					<p>No posts yet — check back soon.</p>
				</div>
			) : (
				<ul class="post-list">
					{posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<span class="post-title">{post.data.title}</span>
								<div class="post-meta">
									<span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
								</div>
							</a>
						</li>
					))}
				</ul>
			)}

		</main>
		<Footer />
	</body>
</html>
