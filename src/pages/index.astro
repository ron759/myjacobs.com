---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* Override global gradient background */
			body {
				background: #f4f6fb;
				background-size: unset;
			}

			/* Remove top padding so hero sits flush under header */
			body > main {
				padding-top: 0;
			}

			/* Hero — full bleed outside the 720px main column */
			.hero {
				background: #1a2744;
				color: white;
				text-align: center;
				padding: 4em 1em 3.5em;
				width: 100vw;
				position: relative;
				left: 50%;
				transform: translateX(-50%);
				margin-bottom: 3em;
			}
			.hero h1 {
				font-size: 3.052em;
				margin-bottom: 0.15em;
				color: white;
			}
			.hero .tagline {
				font-size: 1.15em;
				color: #a8b8d8;
				font-style: italic;
				margin: 0 0 1.75em;
				letter-spacing: 0.02em;
			}
			.hero .intro {
				max-width: 560px;
				margin: 0 auto;
				color: #c8d4e8;
				font-size: 0.95em;
				line-height: 1.8;
			}

			/* Stats */
			.stats {
				display: flex;
				justify-content: center;
				gap: 1.5em;
				margin-top: 2.5em;
				flex-wrap: wrap;
			}
			.stat {
				background: rgba(255,255,255,0.08);
				border: 1px solid rgba(255,255,255,0.15);
				border-radius: 10px;
				padding: 1em 2em;
				text-align: center;
				min-width: 100px;
			}
			.stat .number {
				display: block;
				font-size: 2.2em;
				font-weight: 700;
				color: #f0c060;
				line-height: 1;
			}
			.stat .label {
				font-size: 0.75em;
				color: #a8b8d8;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				margin-top: 0.3em;
				display: block;
			}

			/* Content sections */
			.content-grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 2.5em;
				margin-bottom: 3em;
				align-items: start;
			}

			/* Latest posts */
			.posts-section {
				background: #fff;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 12px;
				padding: 1.75em;
			}
			.section-title {
				font-size: 1.1em;
				font-weight: 700;
				margin-bottom: 0.2em;
				color: rgb(var(--black));
				text-transform: uppercase;
				letter-spacing: 0.06em;
			}
			.section-subtitle {
				color: rgb(var(--gray));
				font-size: 0.85em;
				margin: 0 0 1.25em;
			}
			.post-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.post-list li {
				border-top: 1px solid rgb(var(--gray-light));
				padding: 0.85em 0;
			}
			.post-list li:first-child {
				border-top: none;
				padding-top: 0;
			}
			.post-list a {
				text-decoration: none;
				color: rgb(var(--black));
				display: flex;
				flex-direction: column;
				gap: 0.2em;
			}
			.post-list a:hover .post-title {
				color: var(--accent);
			}
			.post-title {
				font-size: 0.95em;
				font-weight: 600;
				transition: color 0.15s ease;
				line-height: 1.4;
			}
			.post-date {
				font-size: 0.8em;
				color: rgb(var(--gray));
			}
			.view-all {
				display: inline-block;
				margin-top: 1em;
				font-size: 0.85em;
				color: var(--accent);
				text-decoration: none;
				border-top: 1px solid rgb(var(--gray-light));
				padding-top: 0.85em;
				width: 100%;
			}
			.view-all:hover {
				text-decoration: underline;
			}

			/* Gallery CTA */
			.gallery-cta {
				background: #1a2744;
				border-radius: 12px;
				padding: 2em 1.75em;
				text-align: center;
				color: white;
			}
			.gallery-cta h2 {
				font-size: 1.2em;
				margin-bottom: 0.4em;
				color: white;
				text-transform: uppercase;
				letter-spacing: 0.06em;
			}
			.gallery-cta p {
				color: #a8b8d8;
				margin: 0 0 1.5em;
				font-size: 0.9em;
				line-height: 1.6;
			}
			.btn {
				display: inline-block;
				background: #f0c060;
				color: #1a2744;
				padding: 0.6em 1.6em;
				border-radius: 6px;
				text-decoration: none;
				font-size: 0.9em;
				font-weight: 700;
				transition: background 0.15s ease, transform 0.15s ease;
				letter-spacing: 0.03em;
			}
			.btn:hover {
				background: #f5d080;
				color: #1a2744;
				transform: translateY(-2px);
			}

			@media (max-width: 720px) {
				.hero h1 {
					font-size: 2.2em;
				}
				.content-grid {
					grid-template-columns: 1fr;
				}
				.stats {
					gap: 1em;
				}
				.stat {
					padding: 0.85em 1.5em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>

			<!-- Hero / Bio -->
			<section class="hero">
				<h1>The Jacobs Family</h1>
				<p class="tagline">Love God. Love Family. Love People.</p>
				<p class="intro">
					Hey, we're Ron and Vanessa — married, based in Middle Tennessee, and navigating life
					together with 2 grown kids, 4 grandkids, and 3 dogs who run the house. We're both IT people
					by trade, and Vanessa turned our love of travel into a side business helping others
					plan their adventures. This is our little corner of the internet — family updates,
					photos, and whatever's on our minds.
				</p>
				<div class="stats">
					<div class="stat">
						<span class="number">2</span>
						<span class="label">Kids</span>
					</div>
					<div class="stat">
						<span class="number">4</span>
						<span class="label">Grandkids</span>
					</div>
					<div class="stat">
						<span class="number">3</span>
						<span class="label">Dogs</span>
					</div>
				</div>
			</section>

			<!-- Two column: posts + gallery CTA -->
			<div class="content-grid">

				<!-- Latest Blog Posts -->
				<section class="posts-section">
					<p class="section-title">Latest Posts</p>
					<p class="section-subtitle">What's been on our minds lately.</p>
					{posts.length === 0 ? (
						<p style="color: rgb(var(--gray)); font-size: 0.9em;">No posts yet — check back soon.</p>
					) : (
						<ul class="post-list">
							{posts.map(post => (
								<li>
									<a href={`/blog/${post.slug}/`}>
										<span class="post-title">{post.data.title}</span>
										<span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
									</a>
								</li>
							))}
						</ul>
					)}
					<a href="/blog" class="view-all">All posts →</a>
				</section>

				<!-- Gallery CTA -->
				<div class="gallery-cta">
					<h2>📷 Photo Gallery</h2>
					<p>Family trips, everyday moments, and everything in between. Drop in and take a look.</p>
					<a href="/gallery" class="btn">Browse Photos</a>
				</div>

			</div>

		</main>
		<Footer />
	</body>
</html>
